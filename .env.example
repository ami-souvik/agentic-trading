# ============================================================
# NSE LLM Trader — Environment Variables
# Copy to .env (never commit .env)
# ============================================================

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Broker (Phase 2 only — leave empty in Phase 1)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=nse-llm-trader/1.0

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=nse-llm-trader-archive
DYNAMO_TABLE_NAME=nse_trader

# App
PAPER_TRADING_MODE=true
INITIAL_CAPITAL_INR=1000000
MAX_POSITION_PCT=0.15
MAX_OPEN_POSITIONS=5
MAX_HOLD_DAYS=5
CIRCUIT_BREAKER_DRAWDOWN=0.10
DAILY_LLM_BUDGET_USD=1.00

# FastAPI
API_KEY=changeme-local-dev
ENVIRONMENT=development

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO

# Dry-run (generates no real fills, skips DynamoDB writes)
DRY_RUN=false
